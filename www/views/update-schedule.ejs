<%- include('./includes/header.ejs', {
    title: 'Update schedule - Sefinek Blocklist Collection',
    meta: {
        desc: 'This subpage displays the update time of repositories containing the list of blocklists for your time zone. You can refer to it to set up a suitable cron job for updating the blocklist on your instance, such as Pi-hole.',
        tags: 'update, frequency, schedule, pi-hole, cron, time, timezone, date, sefinek, blocklist, collection'
    },
    canonical: '/update-schedule',
    css: 'update-schedule',
    page: 'update-schedule'
}) %>

<main class="main">
    <section class="schedule-info" aria-labelledby="info-heading">
        <h1 class="schedule-info__heading" id="info-heading">Update schedule</h1>
        <p class="schedule-info__text">
            This subpage displays upcoming cron tasks for updating blocklist repositories based on your time zone.
            You can use it as a reference to set up your own cron job for automatic blocklist updates.
        </p>
    </section>

    <section class="schedule-card" aria-labelledby="schedule-card-heading">
        <h2 class="schedule-card__heading sr-only" id="schedule-card-heading">Timezone and schedule information</h2>
        <div class="schedule-card__content">

            <div class="schedule-card__item">
                <strong class="schedule-card__label">Your timezone:</strong>
                <span class="schedule-card__value" id="user-timezone" aria-live="polite">Loading...</span>
            </div>

            <div class="schedule-card__item">
                <strong class="schedule-card__label">Local (blocklist.sefinek.net):</strong>
                <span class="schedule-card__value" id="remote" aria-live="polite">Loading...</span>
            </div>

            <div class="schedule-card__item">
                <strong class="schedule-card__label">Remote (GitHub):</strong>
                <span class="schedule-card__value" id="github" aria-live="polite">Loading...</span>
            </div>
        </div>
    </section>

    <aside class="schedule-note" aria-label="Important information">
        <p class="schedule-note__text">
            - Lists should not be downloaded too frequently, as this may result in a permanent ban on the IP address.
        </p>
        <p class="schedule-note__text">
            - Synchronization occurs daily at 01:00 and 06:00 (24-hour clock, Poland time zone: GMT+01:00).
            Cron expression: <code class="schedule-note__code">0 1,6 * * *</code> (at minute 0, past hours 1 and 6).
            More <a href="https://github.com/sefinek/Sefinek-Blocklist-Collection?tab=readme-ov-file#-update-schedule" target="_blank" rel="noopener" class="schedule-note__link">here</a>.
        </p>
    </aside>
</main>

<script>
    (() => {
        'use strict';

        const showCronInfo = () => {
            try {
                const userTimezone = luxon.DateTime.local().zoneName;
                const timezoneElement = document.getElementById('user-timezone');
                if (timezoneElement) {
                    timezoneElement.textContent = userTimezone;
                }

                const github = luxon.DateTime.fromISO('<%= cron.github %>').setZone(userTimezone);
                const remote = luxon.DateTime.fromISO('<%= cron.remote %>').setZone(userTimezone);

                const githubElement = document.getElementById('github');
                const remoteElement = document.getElementById('remote');

                if (githubElement) {
                    githubElement.textContent = github.toLocaleString(luxon.DateTime.DATETIME_MED);
                }
                if (remoteElement) {
                    remoteElement.textContent = remote.toLocaleString(luxon.DateTime.DATETIME_MED);
                }
            } catch (err) {
                console.error('Failed to load schedule information:', err);
            }
        };

        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', showCronInfo);
        } else {
            showCronInfo();
        }
    })();
</script>

<%- include('./includes/footer.ejs') %>
