<%- include('./includes/header.ejs', {
    title: 'Report False Positive - Sefinek Blocklist Collection',
    meta: {
        desc: 'Found a legitimate domain blocked by our lists? Report false positives easily via email, GitHub Issues, Pull Request, or Discord. Help us improve blocklist accuracy and protect the web better.',
        tags: 'false positive report, blocklist false positive, domain whitelist request, report blocked domain, Sefinek blocklists, DNS filtering, ad blocking, security filtering, contribute blocklist, improve blocklist accuracy'
    },
    canonical: '/false-positives',
    css: 'false-positives',
    page: 'false-positives'
}) %>

<main class="main">
    <header class="page-header">
        <h1 class="page-header__title">Report a false positive</h1>
        <p class="page-header__subtitle">Choose your preferred reporting method</p>
    </header>

    <section class="report-methods" aria-label="Reporting methods">
        <!-- TODO -->
        <a href="mailto:contact@sefinek.net?subject=False%20positive%20report%20-%20DOMAIN%20HERE&body=Hi%2C%0AI'd%20like%20to%20report%20a%20false%20positive%20on%20the%20Sefinek%20Blocklist%20Collection.%0A%0ADomain%20or%20URL%3A%0A%0AReason%3A%0A%0AScreenshots%20(optional)%3A" class="report-card">
            <div class="report-card__icon">
                <img src="/images/flaticon/mail.png" alt="Email icon" width="40" height="40" loading="lazy">
            </div>
            <div class="report-card__content">
                <h2 class="report-card__title">Via email</h2>
                <p class="report-card__description">Send a detailed report directly to our contact address. Pre-filled template makes it easy to submit the domain with justification.</p>
            </div>
        </a>

        <a href="https://github.com/sefinek/Sefinek-Blocklist-Collection/issues" target="_blank" rel="noopener" class="report-card">
            <div class="report-card__icon">🐙</div>
            <div class="report-card__content">
                <h2 class="report-card__title">GitHub Issues</h2>
                <p class="report-card__description">Report a falsely blocked domain in the public repository. Perfect method for transparency and tracking your report status.</p>
            </div>
        </a>

        <a href="https://github.com/sefinek/Sefinek-Blocklist-Collection?tab=readme-ov-file#-contributing" target="_blank" rel="noopener" class="report-card">
            <div class="report-card__icon">🔀</div>
            <div class="report-card__content">
                <h2 class="report-card__title">Pull Request</h2>
                <p class="report-card__description">Remove the domain from the list yourself and submit a PR with the fix. Make sure to read the contributing guidelines first.</p>
            </div>
        </a>

        <a href="https://discord.gg/53DBjTuzgZ" target="_blank" rel="noopener" class="report-card">
            <div class="report-card__icon">💬</div>
            <div class="report-card__content">
                <h2 class="report-card__title">Discord Server</h2>
                <p class="report-card__description">Join our community and report the issue on Discord server. Quick contact with the team and other users.</p>
            </div>
        </a>
    </section>
</main>

