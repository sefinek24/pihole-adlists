<!DOCTYPE html> <!-- Copyright 2023-2026 © by Sefinek. All Rights Reserved. -->
<html lang="en">
<head>
    <meta charset="utf-8">
    <% if (title) { %><title><%= title %></title><meta property="og:title" content="<%= title %>"><% } %>
    <% if (meta.desc) { %><meta name="description" content="<%= meta.desc %>"><meta property="og:description" content="<%= meta.desc %>"><meta name="twitter:description" content="<%= meta.desc %>"><% } %>
    <% if (meta.tags) { %><meta name="keywords" content="<%= meta.tags %>"><% } %>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <% if (canonical || canonical === '') { %><link rel="canonical" href="<%= process.env.DOMAIN %><%= canonical %>"><% } %>

    <!-- CSS -->
    <link rel="stylesheet" href="/css/global.css">
    <link rel="stylesheet" href="/css/navbar.css">
    <% if (css) { %><link rel="stylesheet" href="/css/<%= css %>.css"> <% } %>

    <!-- SEO -->
    <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png">
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    <link rel="shortcut icon" type="image/x-icon" href="/favicon.ico">
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
    <link rel="manifest" href="/site.webmanifest">
    <meta name="application-name" content="Sefinek Blocklist Collection">
    <meta name="apple-mobile-web-app-title" content="Sefinek Blocklist Collection">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="theme-color" content="#223672">
    <meta property="og:locale" content="en_US">
    <meta property="og:type" content="website">
    <meta property="og:site_name" content="Sefinek Blocklist Collection">
    <meta property="og:url" content="https://blocklist.sefinek.net">
    <meta property="og:image" content="https://blocklist.sefinek.net/images/meta-og.jpg">
    <meta property="twitter:card" content="summary_large_image">
    <meta property="twitter:url" content="https://blocklist.sefinek.net">
    <meta property="twitter:title" content="Sefinek Blocklist Collection">
    <meta property="twitter:image" content="https://blocklist.sefinek.net/images/meta-og.jpg">
    <meta property="twitter:image:alt" content="Sefinek Blocklist Collection banner">
</head>
<body>
    <nav>
        <div class="nav-container">
            <div class="nav-brand">
                <img src="https://sefinek.net/favicon.png" alt="Sefinek logo" class="brand-icon" width="32" height="32" loading="eager">
                <span class="brand-text">Sefinek Blocklists</span>
            </div>
            <button class="menu-toggle" aria-label="Toggle navigation menu">
                <span></span>
                <span></span>
                <span></span>
            </button>
            <ul class="nav-menu">
                <li><a href="/" <%- page === 'home' ? 'class="active"' : '' %>>Home</a></li>
                <li><a href="/generated/v1" <%- page === 'blocklists' ? 'class="active"' : '' %>>Blocklists</a></li>
                <li><a href="/docs" <%- page === 'docs' ? 'class="active"' : '' %>>Docs</a></li>
                <li><a href="/metrics" <%- page === 'metrics' ? 'class="active"' : '' %>>Metrics</a></li>
                <li><a href="/false-positives" <%- page === 'false-positives' ? 'class="active"' : '' %>>Report</a></li>
                <li><a href="/update-schedule" <%- page === 'update-schedule' ? 'class="active"' : '' %>>Schedule</a></li>
                <li><a href="/logs/v1" <%- page === 'git-logs' ? 'class="active"' : '' %>>Logs</a></li>
            </ul>
        </div>
    </nav>

