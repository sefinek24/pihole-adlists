<%- include('./includes/header.ejs', {
    title: 'Metrics - Sefinek Blocklists',
    meta: {
        desc: 'Real-time metrics and statistics for Sefinek Blocklists',
        tags: 'metrics, statistics, analytics, blocklist stats'
    },
    canonical: '/metrics',
    css: 'metrics',
    page: 'metrics'
}) %>

<main class="metrics-container">
    <h1>📊 Blocklist Metrics</h1>

    <section class="all-time-section">
        <h2>🌍 All-Time Statistics</h2>
        <div class="stats-summary">
            <div class="stat-card all-time">
                <h3>Total Requests</h3>
                <p id="alltime-total">-</p>
                <span class="stat-label">Since October 2024</span>
            </div>
            <div class="stat-card all-time">
                <h3>Blocklist Downloads</h3>
                <p id="alltime-blocklists">-</p>
                <span class="stat-label">All formats combined</span>
            </div>
            <div class="stat-card all-time">
                <h3>Most Popular Format</h3>
                <p id="alltime-top-category">-</p>
                <span class="stat-label">By request count</span>
            </div>
            <div class="stat-card all-time">
                <h3>Avg Requests/Day</h3>
                <p id="alltime-avg">-</p>
                <span class="stat-label">Based on history</span>
            </div>
            <div class="stat-card all-time">
                <h3>Success Rate</h3>
                <p id="alltime-success-rate">-</p>
                <span class="stat-label">2xx/3xx responses</span>
            </div>
        </div>
    </section>

    <section class="time-range-section">
        <h2>📅 Time Range Analytics <span class="utc-badge">UTC</span></h2>

        <div class="date-controls">
            <div class="quick-select">
                <button class="btn-quick" data-days="7">Last 7 Days</button>
                <button class="btn-quick active" data-days="14">Last 14 Days</button>
                <button class="btn-quick" data-days="30">Last 30 Days</button>
                <button class="btn-quick" data-days="90">Last 90 Days</button>
            </div>

            <div class="date-divider">
                <span>or</span>
            </div>

            <div class="date-range">
                <div class="date-input-group">
                    <label for="date-from">From</label>
                    <input type="date" id="date-from" />
                </div>

                <div class="date-input-group">
                    <label for="date-to">To</label>
                    <input type="date" id="date-to" />
                </div>

                <button id="load-data" class="btn-primary">Apply Custom Range</button>
            </div>
        </div>

        <div class="interval-controls">
            <label>Time Interval:</label>
            <div class="interval-select">
                <button class="btn-interval" data-interval="1">1 min</button>
                <button class="btn-interval active" data-interval="10">10 min</button>
                <button class="btn-interval" data-interval="30">30 min</button>
                <button class="btn-interval" data-interval="120">2h</button>
                <button class="btn-interval" data-interval="360">6h</button>
                <button class="btn-interval" data-interval="720">12h</button>
                <button class="btn-interval" data-interval="1440">24h</button>
            </div>
        </div>

        <div class="stats-summary">
            <div class="stat-card filtered">
                <h3>Total Requests</h3>
                <p id="total-requests">-</p>
                <span class="stat-label">In selected range</span>
            </div>
            <div class="stat-card filtered">
                <h3>Blocklist Downloads</h3>
                <p id="blocklist-requests">-</p>
                <span class="stat-label">Downloads only</span>
            </div>
            <div class="stat-card filtered">
                <h3>Success Rate</h3>
                <p id="success-rate">-</p>
                <span class="stat-label">2xx/3xx responses</span>
            </div>
            <div class="stat-card filtered">
                <h3>Average Per Hour</h3>
                <p id="avg-per-hour">-</p>
                <span class="stat-label">Hourly average</span>
            </div>
            <div class="stat-card filtered">
                <h3>Error Rate</h3>
                <p id="error-rate">-</p>
                <span class="stat-label">4xx/5xx responses</span>
            </div>
            <div class="stat-card filtered">
                <h3>Most Popular Format</h3>
                <p id="period-top-category">-</p>
                <span class="stat-label">Top in range</span>
            </div>
            <div class="stat-card filtered">
                <h3>Days Analyzed</h3>
                <p id="unique-days">-</p>
                <span class="stat-label">In date range</span>
            </div>
        </div>

        <div class="peak-minute-banner">
            <span class="peak-label">🔥 Top 3 Busiest Intervals:</span>
            <div class="peak-list" id="peak-times">
                <span class="peak-item">-</span>
            </div>
        </div>
    </section>

    <div class="charts-grid">
        <div class="chart-container chart-full-width">
            <h2>📈 Requests Over Time</h2>
            <canvas id="requests-chart"></canvas>
        </div>

        <div class="chart-container">
            <h2>📅 Traffic by Day</h2>
            <canvas id="daily-chart"></canvas>
        </div>

        <div class="chart-container">
            <h2>⏰ Traffic by Hour</h2>
            <canvas id="hourly-chart"></canvas>
        </div>

        <div class="chart-container">
            <h2>🔥 Top 10 Peak Hours</h2>
            <canvas id="peak-hours-chart"></canvas>
        </div>

        <div class="chart-container">
            <h2>📊 Format Trends</h2>
            <canvas id="format-distribution-chart"></canvas>
        </div>

        <div class="chart-container">
            <h2>🎯 Format Totals</h2>
            <canvas id="categories-chart"></canvas>
        </div>

        <div class="chart-container">
            <h2>✅ HTTP Response Codes</h2>
            <canvas id="responses-chart"></canvas>
        </div>
    </div>

    <div id="loading" class="loading" style="display: none;">
        <div class="spinner"></div>
        <p>Loading metrics...</p>
    </div>
</main>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js"></script>
<script src="/js/metrics.js"></script>

<%- include('./includes/footer.ejs') %>
