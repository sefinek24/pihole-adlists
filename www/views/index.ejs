const responseCodes = responsesObj ? Object.keys(responsesObj).sort() : [];
const wsUrl = process.env.NODE_ENV === 'production' ? process.env.WS_ADDRESS : `${process.env.WS_ADDRESS}:${process.env.WS_PORT}`;
