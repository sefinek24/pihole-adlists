<%- include('../includes/header.ejs', {
    title: `Blocklists ${currentPath} - Sefinek Blocklist Collection`,
    meta: {
        desc: `Explore static directory (${currentPath}) of blocklists.`,
        tags: 'explorer, sefinek explorer, view files, view blocklists, sefinek all blocklists'
    },
    canonical: currentPath,
    css: 'explorer',
    page: 'blocklists'
}) %>

<main class="main" role="main">
    <article class="explorer" aria-label="File Explorer">
        <header class="explorer__header">
            <h1 class="explorer__title">
                <span class="explorer__icon" aria-hidden="true">📁</span>
                <span class="explorer__path"><%= currentPath %></span>
            </h1>
            <button type="button" class="explorer__action" id="reloadPage" aria-label="Reload current directory">
                <span aria-hidden="true">🔃</span> Reload
            </button>
        </header>

        <div class="explorer__content" role="region" aria-label="Directory listing">
            <table class="explorer__table" id="explorerTable">
                <thead class="explorer__thead">
                    <tr>
                        <th class="explorer__th explorer__th--name" scope="col">Name</th>
                        <th class="explorer__th explorer__th--date" scope="col">Date modified</th>
                        <th class="explorer__th explorer__th--size" scope="col">Size</th>
                    </tr>
                </thead>
                <tbody class="explorer__tbody">
                <% if (currentPath !== '/generated/v1') { %>
                    <tr class="explorer__row explorer__row--parent">
                        <td class="explorer__cell explorer__cell--name">
                            <a href="<%= currentPath.replace(/\/$/, '').split('/').slice(0, -1).join('/') %>/" class="explorer__link" aria-label="Parent directory" data-ajax-link>
                                <img src="/images/flaticon/back.png" alt="" class="explorer__img" width="24" height="24" loading="lazy">
                                <span class="explorer__name">../</span>
                            </a>
                        </td>
                        <td class="explorer__cell explorer__cell--date"></td>
                        <td class="explorer__cell explorer__cell--size"></td>
                    </tr>
                <% } %>
                <% files.forEach(file => { %>
                    <tr class="explorer__row <%= file.isDirectory ? 'explorer__row--folder' : 'explorer__row--file' %>">
                        <td class="explorer__cell explorer__cell--name">
                            <a href="<%= currentPath.replace(/\/$/, '') %>/<%= file.name %>" class="explorer__link" aria-label="<%= file.isDirectory ? 'Folder' : 'File' %>: <%= file.name %>" <%= file.isDirectory ? 'data-ajax-link' : '' %>>
                                <img src="/images/flaticon/<%= file.icon %>" alt="" class="explorer__img" width="24" height="24" loading="lazy">
                                <span class="explorer__name"><%= file.name %></span>
                            </a>
                        </td>
                        <td class="explorer__cell explorer__cell--date" data-timestamp="<%= file.lastModified %>"></td>
                        <td class="explorer__cell explorer__cell--size"><%= file.formattedSize %></td>
                    </tr>
                <% }); %>
                </tbody>
            </table>
        </div>
    </article>
</main>

<script src="/js/explorer.js"></script>

<%- include('../includes/footer.ejs') %>