  "type": "commonjs",
  "main": "www/index.js",
  "scripts": {
    "m": "ncu -u && npm i && npm update && npm audit fix",
    "pull": "git fetch origin && git reset --hard origin/main",
    "pull:blocklists": "git -C blocklists fetch origin +refs/heads/blocklists:refs/remotes/origin/blocklists && git -C blocklists reset --hard origin/blocklists",
    "pullsh": "bash bash/pull.sh",
    "test": "node scripts/test-urls.js",
    "update": "npm run pull && npm run pull:blocklists && npm ci --omit=dev && pm2 restart blocklist"
  },
  "dependencies": {
    "axios": "^1.15.0",
    "cron-parser": "^5.5.0",
    "ejs": "^5.0.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "express-timeout-handler": "^2.2.2",
    "express-validator": "^7.3.2",
    "helmet": "^8.1.0",
    "lzma-native": "^8.0.6",
    "marked": "^18.0.0",
    "mongoose": "^9.4.1",
    "morgan": "^1.10.1",
    "nodemailer": "^8.0.5",
    "rate-limit-redis": "^4.3.1",
    "redis": "^5.11.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "globals": "^17.5.0",
    "ipaddr.js": "^2.3.0",
    "kleur": "^4.1.5",
    "unzipper": "^0.12.3",
    "validator": "^13.15.35"
  },
  "engines": {
    "node": ">=20.12.0"
  }
}
